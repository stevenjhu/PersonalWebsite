---
import { profile } from "../data/profile";
const year = new Date().getFullYear();
---

<footer class="border-border/60 border-t">
  <div
    class="mx-auto flex max-w-5xl flex-col items-center justify-between gap-4 px-6 py-10 sm:flex-row"
  >
    <p class="text-muted font-mono text-sm">
      © {year} {profile.name}
    </p>
    <ul class="flex items-center gap-5">
      {
        profile.socials.map((s) => (
          <li>
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              class="text-muted hover:text-text text-sm transition-colors"
            >
              {s.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</footer>
