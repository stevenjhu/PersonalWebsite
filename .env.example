# Copy to .env and fill in. NEVER commit the real .env (it is git-ignored).
# Values are provided/created during setup — see the project owner's notes, not the repo.

# --- Cloudflare R2 (photo upload script) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public base URL where the bucket is served (custom domain or r2.dev URL)
R2_PUBLIC_BASE=

# --- Contact form (Azure Functions; set as Azure app settings in prod) ---
RESEND_API_KEY=
CONTACT_TO=
CONTACT_FROM=
