# Copy to .env and fill in. NEVER commit the real .env (it is git-ignored).
# Values are provided/created during setup — see the project owner's notes, not the repo.

# --- Cloudflare R2 (photo upload script) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

R2_ACCESS_KEY_ID_PHOTO=
R2_SECRET_ACCESS_KEY_PHOTO=
R2_PUBLIC_BASE_PHOTO=
R2_BUCKET_PHOTO=

# --- Contact form proxy (Cloudflare Worker) ---
AZURE_CONTACT_URL=
CONTACT_FORM_SECRET=

# --- Contact form (Cloudflare Worker secrets; set via `wrangler secret put`) ---
RESEND_API_KEY=
CONTACT_TO=
CONTACT_FROM=
