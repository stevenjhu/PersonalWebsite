---
import SectionHeading from "../components/SectionHeading.astro";
import TechTag from "../components/TechTag.astro";
import { experience } from "../data/experience";
import { profile } from "../data/profile";
import { Download } from "lucide-react";
---

<section id="experience" class="border-border/60 bg-surface/40 border-t">
  <div class="mx-auto max-w-5xl px-6 py-20">
    <SectionHeading id="experience-heading" title="Where I've worked" />

    <ol class="border-border relative flex flex-col gap-10 border-l pl-6">
      {
        experience.map((job) => (
          <li class="relative">
            <span class="border-accent bg-bg absolute top-1.5 -left-[31px] h-3 w-3 rounded-full border-2" />
            <div class="flex flex-wrap items-baseline justify-between gap-2">
              <h3 class="text-lg font-semibold">
                {job.role} ·{" "}
                <span class="text-accent-strong">{job.company}</span>
              </h3>
              <span class="text-muted font-mono text-sm">{job.period}</span>
            </div>
            {job.location && (
              <p class="text-muted mt-0.5 text-sm">{job.location}</p>
            )}
            <ul class="text-muted mt-3 list-disc space-y-1.5 pl-5">
              {job.highlights.map((h) => (
                <li>{h}</li>
              ))}
            </ul>
            <div class="mt-4 flex flex-wrap gap-2">
              {job.tech.map((t) => (
                <TechTag label={t} />
              ))}
            </div>
          </li>
        ))
      }
    </ol>

    <a
      href={profile.resumeUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="border-border hover:bg-surface mt-10 inline-flex items-center gap-2 rounded-lg border px-5 py-2.5 font-medium transition-colors"
    >
      <Download size={16} aria-hidden />
      Download résumé
    </a>
  </div>
</section>
