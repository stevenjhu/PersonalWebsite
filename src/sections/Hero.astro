---
import { ArrowRight, ChevronDown } from "lucide-react";
import { profile } from "../data/profile";
---

<section id="top" class="relative flex min-h-[calc(100dvh-4rem)] flex-col overflow-hidden">
  <!-- Subtle warm radial wash behind the hero (late-afternoon light). -->
  <div aria-hidden class="hero-wash pointer-events-none absolute inset-0 -z-10"></div>

  <!-- Main content — centers within the flex-1 area so it never floats to the middle of excessive whitespace -->
  <div class="flex flex-1 items-center">
    <div class="mx-auto flex w-full max-w-5xl flex-col px-6 py-16">
      <p class="text-accent-strong mb-4 font-mono text-sm tracking-wide">
        {profile.eyebrow}
      </p>
      <h1 class="text-display max-w-3xl">
        {profile.name}<span class="text-accent">.</span><span class="hero-alias">{profile.shortName}</span>
      </h1>
      <p class="text-muted mt-6 max-w-2xl text-lg sm:text-xl">
        {profile.tagline}
      </p>

      <div class="mt-10 flex flex-wrap items-center gap-4">
        <a href="#experience" class="hero-cta">
          View work
          <ArrowRight size={16} aria-hidden />
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll hint — anchored to the bottom of the hero viewport, creates vertical tension -->
  <a
    href="#about"
    aria-label="Scroll to about"
    class="scroll-cue text-muted mx-auto inline-flex pb-8 opacity-40 transition-opacity hover:opacity-70 sm:pb-10"
  >
    <ChevronDown size={22} aria-hidden />
  </a>
</section>

<style>
  /* The name people actually call him — a quiet alias trailing the period,
     sized down so it reads as an aside, not a second headline. */
  .hero-alias {
    font-size: 0.3em;
    font-weight: 500;
    letter-spacing: 0;
    margin-left: 0.4em;
    color: var(--muted);
  }

  /* Primary CTA: accent fill with espresso ink; on hover it deepens to muted
     earth with cream ink and the arrow steps forward. Colors are fixed so the
     button reads identically in light and dark. */
  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.4rem;
    border-radius: 0.5rem;
    background: var(--accent);
    color: #2a201c;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    transition:
      background-color 0.2s ease,
      color 0.2s ease;
  }

  .hero-cta:hover {
    background: #a48374;
    color: #f1ede6;
  }

  .hero-cta svg {
    transition: transform 0.2s ease;
  }

  .hero-cta:hover svg {
    transform: translateX(3px);
  }

  /* color-mix keeps the wash tied to the live accent token (and theme). */
  .hero-wash {
    background-image: radial-gradient(
      60% 60% at 30% 20%,
      color-mix(in oklab, var(--accent) 22%, transparent),
      transparent 70%
    );
  }

  /* Gentle downward nudge — transform only, no layout property animation. */
  .scroll-cue {
    animation: scroll-nudge 2.4s ease-in-out infinite;
  }

  @keyframes scroll-nudge {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(5px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-cue {
      animation: none;
    }

    .hero-cta,
    .hero-cta svg {
      transition: none;
    }
  }
</style>
