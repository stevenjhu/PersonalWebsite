{
	"extends": "astro/tsconfigs/strict",
	"include": [
		".astro/types.d.ts",
		"**/*",
		"./worker-configuration.d.ts"
	],
	"exclude": [
		"dist",
		"api",
		"scripts"
	],
	"compilerOptions": {
		"jsx": "react-jsx",
		"jsxImportSource": "react",
		"strict": true,
		"verbatimModuleSyntax": true,
		"paths": {
			"@/*": [
				"./src/*"
			]
		}
	}
}